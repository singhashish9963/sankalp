# Backend runtime
PORT=3001
FRONTEND_URL=https://next-step-ai-sankalp.vercel.app
CORS_ORIGINS=https://next-step-ai-sankalp.vercel.app,http://localhost:3000,http://localhost:5173

# Data stores
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/postgres
QDRANT_URL=https://<cluster>.cloud.qdrant.io
QDRANT_API_KEY=<qdrant_api_key>

# AI service integrations
OPENROUTER_API_KEY=<openrouter_api_key>
OPENROUTER_REFERER=https://next-step-ai-sankalp.vercel.app
DEEPGRAM_API_KEY=<deepgram_api_key>
DEEPGRAM_VOICE=alloy
DEEPGRAM_MODEL=aura-2-thalia-en
GEMINI_API_KEY=<gemini_api_key>

# Flask AI service URL (deployed)
FLASK_ANALYSIS_URL=https://<your-ai-service>.onrender.com
